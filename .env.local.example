 ════════════════════════════════════════════
# SPY ON THE RISE: Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local to GitHub.
# ════════════════════════════════════════════

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://spyontherise.com

# Google Analytics 4 Measurement ID
# Get from: analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Mailchimp Newsletter Integration
# Get from: Mailchimp → Account → Extras → API Keys
NEXT_PUBLIC_MAILCHIMP_URL=https://xxx.us1.list-manage.com/subscribe/post?u=xxx&id=xxx

# Sanity CMS (when connected)
# Get from: sanity.io/manage → your project
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
